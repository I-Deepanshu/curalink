# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/curalink?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# ── NCBI / PubMed ────────────────────────────────────────────────────────────
# Register free at https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/
NCBI_API_KEY=your_ncbi_api_key_here

# ── OpenAlex polite pool (use your own email) ─────────────────────────────────
OPENALEX_EMAIL=your@email.com

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Hugging Face fallback ─────────────────────────────────────────────────────
# Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
